// prisma/schema.prisma
// Alfarida Company — Database Schema
// Powered by Supabase (PostgreSQL) + Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// AUTH
// ─────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  role          Role      @default(ADMIN)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("users")
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
}

// ─────────────────────────────────────────────
// PROJECTS
// ─────────────────────────────────────────────

model Project {
  id              String          @id @default(cuid())
  slug            String          @unique
  status          ProjectStatus   @default(DRAFT)
  featured        Boolean         @default(false)
  order           Int             @default(0)

  // Bilingual content
  titleAr         String
  titleEn         String
  descriptionAr   String          @db.Text
  descriptionEn   String          @db.Text
  clientAr        String?
  clientEn        String?
  locationAr      String?
  locationEn      String?

  // Media
  coverImage      String?
  images          String[]        @default([])

  // Meta
  category        ProjectCategory @default(OTHER)
  tags            String[]        @default([])
  completedAt     DateTime?
  externalUrl     String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, featured])
  @@index([category])
  @@map("projects")
}

enum ProjectStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ProjectCategory {
  CONSTRUCTION
  INFRASTRUCTURE
  INTERIOR
  INDUSTRIAL
  COMMERCIAL
  RESIDENTIAL
  OTHER
}

// ─────────────────────────────────────────────
// SERVICES
// ─────────────────────────────────────────────

model Service {
  id              String    @id @default(cuid())
  slug            String    @unique
  icon            String?
  order           Int       @default(0)
  published       Boolean   @default(true)

  titleAr         String
  titleEn         String
  descriptionAr   String    @db.Text
  descriptionEn   String    @db.Text
  featuresAr      String[]  @default([])
  featuresEn      String[]  @default([])

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("services")
}

// ─────────────────────────────────────────────
// INQUIRIES (Contact / Lead form)
// ─────────────────────────────────────────────

model Inquiry {
  id          String          @id @default(cuid())
  status      InquiryStatus   @default(NEW)

  // Sender info
  name        String
  email       String
  phone       String?
  company     String?

  // Message
  subject     String?
  messageAr   String?         @db.Text
  messageEn   String?         @db.Text
  message     String          @db.Text

  // Meta
  locale      String          @default("ar")
  source      String?         // "website" | "referral" | etc.
  ipAddress   String?
  userAgent   String?

  // Admin
  notes       String?         @db.Text
  assignedTo  String?
  resolvedAt  DateTime?

  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([status])
  @@index([createdAt])
  @@map("inquiries")
}

enum InquiryStatus {
  NEW
  IN_PROGRESS
  RESPONDED
  CLOSED
  SPAM
}

// ─────────────────────────────────────────────
// SITE SETTINGS (key/value store)
// ─────────────────────────────────────────────

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @db.Text
  type      String   @default("text") // "text" | "json" | "boolean" | "number"
  group     String   @default("general")

  updatedAt DateTime @updatedAt

  @@index([group])
  @@map("site_settings")
}
